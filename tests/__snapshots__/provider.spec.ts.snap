exports[`ProviderManager enhancements > should render a facebook iframe element when asked 1`] = `
<div
  className="w-full bg-black rounded-lg overflow-hidden provider-facebook "
>
  <div
    className="aspect-video w-full"
  >
    <iframe
      allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; fullscreen; web-share"
      allowFullScreen={true}
      className="w-full h-full"
      frameBorder="0"
      height="100%"
      src="https://www.facebook.com/plugins/video.php?href=https%3A%2F%2Fwww.facebook.com%2FNotrePage%2Fvideos%2F123456789%2F&width=560&show_text=false&appId"
      title="Facebook Live Player"
      width="100%"
    />
  </div>
</div>
`;
